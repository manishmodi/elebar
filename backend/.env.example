# Copy to backend/.env for local development. NEVER commit real values.

# Core — REQUIRED in production (boot refuses defaults)
SECRET_KEY=change-me-50-random-chars
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (unset -> SQLite fallback for zero-service dev)
DATABASE_URL=postgres://sherpa:sherpa@localhost:5432/sherpa

# Cache (Redis is cache-only; unset -> locmem)
REDIS_URL=redis://localhost:6379/0
# Broker (RabbitMQ); with CELERY_TASK_ALWAYS_EAGER=1 no broker is needed
CELERY_BROKER_URL=amqp://sherpa:sherpa@localhost:5672//
CELERY_TASK_ALWAYS_EAGER=1

# Frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=

# Org reporting timezone (storage is always UTC)
ORG_TIMEZONE=Asia/Kathmandu

# Yango Fleet API — leave empty until real credentials exist; the integration
# reports "not configured" and never sends traffic without them.
YANGO_CLIENT_ID=
YANGO_PARK_ID=
YANGO_API_KEY=
YANGO_WORK_RULE_ID=
