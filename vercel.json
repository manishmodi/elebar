{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile --ignore-scripts && pnpm rebuild -r",
  "buildCommand": "pnpm --filter @workspace/elebhar run build",
  "outputDirectory": "artifacts/elebhar/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://elebhar-api-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
