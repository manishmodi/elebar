# Local development image for the Elebhar FMS pnpm monorepo.
#
# Debian-based (glibc) ON PURPOSE: the pnpm-workspace.yaml `overrides` strip all
# native binaries except the linux-x64-gnu ones (rollup/esbuild/tailwind oxide/
# lightningcss). An Alpine/musl image would fail to install. Do NOT switch to alpine.
FROM node:24-bookworm-slim

# git + certs: some postinstall/build scripts and TLS fetches need them.
RUN apt-get update \
  && apt-get install -y --no-install-recommends git ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Pin pnpm to match the host / lockfile.
RUN corepack enable && corepack prepare pnpm@11.0.9 --activate

WORKDIR /app

# Install once into the image. At runtime docker-compose bind-mounts the source
# over /app and preserves these node_modules via anonymous volumes, so edits are
# live but dependencies come from the image (fast, isolated from the Windows host).
COPY . .
# The repo's root `preinstall` guard rejects installs whose npm_config_user_agent
# isn't `pnpm/*`. pnpm 11 doesn't pass that var to lifecycle scripts, so the guard
# misfires inside Docker. Install with --ignore-scripts (which also skips that
# guard), then `pnpm rebuild` to run the native build scripts that genuinely need
# them (esbuild, @swc/core, msw, unrs-resolver — the onlyBuiltDependencies list).
RUN pnpm install --frozen-lockfile --ignore-scripts \
  && pnpm rebuild -r

# Overridden per-service in docker-compose.yml.
CMD ["pnpm", "-r", "run", "dev"]
