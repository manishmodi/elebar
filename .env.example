# Environment contract for the Elebhar Fleet Management System.
# Copy to `.env.docker` for local Docker dev, or set these in Railway/Vercel for prod.
# (Real .env* files are gitignored — never commit secrets.)

# ── Database ──────────────────────────────────────────────────────────────────
# Dev (Docker): postgres://elebhar:elebhar@db:5432/elebhar
# Prod: Neon connection string (postgres://...neon.tech/...?sslmode=require)
DATABASE_URL=

# ── Sessions ──────────────────────────────────────────────────────────────────
# Required in production (the app refuses to start without it when NODE_ENV=production).
SESSION_SECRET=

# ── HTTP port ─────────────────────────────────────────────────────────────────
# Dev: api=8080, web=5173 (set per-service). Prod: platform-assigned.
PORT=

# ── Object storage ────────────────────────────────────────────────────────────
# Driver selects the backend: "s3" (MinIO/S3-compatible, default) or "vercel-blob".
STORAGE_DRIVER=s3
# Dev: MinIO (S3-compatible). Prod: Vercel Blob (uses BLOB_READ_WRITE_TOKEN instead).
# Uploads are server-proxied (browser POSTs the file to the API), so the same flow
# works across both drivers. Dev uses these S3 vars:
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BUCKET=elebhar-public
S3_PRIVATE_BUCKET=elebhar-private
S3_FORCE_PATH_STYLE=true
# Prod (Vercel Blob):
# BLOB_READ_WRITE_TOKEN=

# ── Yango fleet API (optional; blank disables sync) ───────────────────────────
YANGO_API_KEY=
YANGO_CLIENT_ID=
YANGO_PARK_ID=

# ── Temp prod-sync button (removed after cutover) ─────────────────────────────
# Read-only source connection used by the admin "Sync from Production" button.
SOURCE_DATABASE_URL=

# Service token for /api/fleet/v1 (Riders Club backend). Generate a long random value for prod.
FLEET_SERVICE_TOKEN=
