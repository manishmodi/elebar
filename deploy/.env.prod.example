# Production environment for the sherpa stack.
# Copy to deploy/.env.prod on the server and fill every CHANGE_ME.
# deploy/.env.prod is gitignored — secrets never enter the repo.

# --- Django core ---
SECRET_KEY=CHANGE_ME_50_random_chars
DEBUG=0
ALLOWED_HOSTS=erp.sherpamobility.com,127.0.0.1,localhost
# 127.0.0.1/localhost stay in the list for container healthchecks.
CSRF_TRUSTED_ORIGINS=https://erp.sherpamobility.com
CORS_ALLOWED_ORIGINS=https://erp.sherpamobility.com

# --- Datastores (service names from docker-compose.prod.yml) ---
POSTGRES_DB=sherpa
POSTGRES_USER=sherpa
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgres://sherpa:CHANGE_ME@db:5432/sherpa
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=0

# --- Org ---
ORG_TIMEZONE=Asia/Kathmandu

# --- Yango Fleet API (leave empty to keep the integration inert) ---
YANGO_CLIENT_ID=
YANGO_PARK_ID=
YANGO_API_KEY=
YANGO_WORK_RULE_ID=

# --- Tuning ---
WEB_CONCURRENCY=4
LOG_LEVEL=INFO
